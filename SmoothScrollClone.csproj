<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>

    <!-- Branding -->
    <AssemblyName>SoftScroll</AssemblyName>
    <RootNamespace>SoftScroll</RootNamespace>
    <Product>Soft Scroll</Product>
    <Company>Soft Scroll</Company>
    <Description>Soft Scroll brings smooth, configurable scrolling to Windows.</Description>
    <!--
      Single source of truth for the app version. Runtime code reads this via
      SoftScroll.Infrastructure.AppVersion (which inspects AssemblyInformationalVersion /
      AssemblyVersion). The release-please workflow updates this value on each release.
      Do NOT hard-code the version string in any .cs / .xaml source file.
    -->
    <Version>0.3.3</Version>
    <AssemblyVersion>0.3.3</AssemblyVersion>
    <FileVersion>0.3.3</FileVersion>
    <InformationalVersion>0.3.3</InformationalVersion>

    <!-- App executable icon -->
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Logging -->
    <PackageReference Include="Serilog" Version="4.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Embed as Resource for pack URI -->
    <Resource Include="Assets\app.ico" />
    <Resource Include="Assets\logo.svg" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Update="Resources\Strings.resx">
      <Generator>PublicResXFileCodeGenerator</Generator>
      <LastGenOutput>Strings.Designer.cs</LastGenOutput>
    </EmbeddedResource>
    <EmbeddedResource Update="Resources\Strings.vi.resx" />
    <EmbeddedResource Update="Resources\Strings.zh.resx" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include=".github\workflows\" />
  </ItemGroup>

  <!-- Kill any running instance before build to avoid file lock -->
  <Target Name="KillRunningInstance" BeforeTargets="BeforeBuild">
    <Exec Command="taskkill /F /IM $(AssemblyName).exe /T 2>nul" IgnoreExitCode="true" IgnoreStandardErrorWarningFormat="true" />
  </Target>

</Project>
