<Window x:Class="SoftScroll.UI.ScrollIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="64" Height="64"
             WindowStyle="None"
             AllowsTransparency="True"
             Background="Transparent"
             IsHitTestVisible="False"
             ShowInTaskbar="False"
             Topmost="True"
             WindowStartupLocation="Manual"
             Loaded="OnLoaded">
    <Grid>
        <!-- Shadow effect -->
        <Border x:Name="Container"
                CornerRadius="8"
                Background="#CC1A1A1A"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            
            <Grid Margin="8">
                <!-- Scroll icon -->
                <TextBlock Text="~"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#3B82F6"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,2,0,0"/>
                
                <!-- Speed value in center -->
                <TextBlock x:Name="SpeedText"
                           Text="0"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                
                <!-- Direction hint at bottom -->
                <TextBlock Text="px"
                           FontSize="9"
                           Foreground="#60FFFFFF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,2"/>
            </Grid>
        </Border>
    </Grid>
</Window>
