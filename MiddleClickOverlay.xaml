<Window x:Class="SoftScroll.MiddleClickOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" IsHitTestVisible="False"
        Width="100" Height="100"
        WindowStartupLocation="Manual">
    <!-- 
       MATH-PERFECT SYMMETRY DESIGN:
       1. All arrows share the EXACT same Geometry.
       2. Each arrow is placed in a 100x100 container (the full Window).
       3. Each arrow is rotated around the EXACT center (50,50) using RenderTransformOrigin="0.5,0.5".
       4. This guarantees that Top/Bottom/Left/Right are mirrors of each other.
    -->
    <Grid>
        <!-- Background Glow -->
        <Ellipse x:Name="BackgroundGlow" Width="70" Height="70" Fill="#20000000" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Ellipse.Effect>
                <BlurEffect Radius="20"/>
            </Ellipse.Effect>
        </Ellipse>
        
        <!-- Subtle glass ring -->
        <Ellipse Width="64" Height="64" Stroke="#20FFFFFF" StrokeThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center" />

        <!-- All arrows are in this container to ensure they share the same center -->
        <Grid Width="100" Height="100" RenderTransformOrigin="0.5,0.5">
            
            <!-- UP (Rotate 0) -->
            <Path x:Name="ArrowUp" Stroke="#60FFFFFF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 42,32 L 50,24 L 58,32" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- DOWN (Rotate 180) -->
            <Path x:Name="ArrowDown" Stroke="#60FFFFFF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 42,32 L 50,24 L 58,32" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                <Path.RenderTransform>
                    <RotateTransform Angle="180" />
                </Path.RenderTransform>
            </Path>

            <!-- LEFT (Rotate -90) -->
            <Path x:Name="ArrowLeft" Stroke="#60FFFFFF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 42,32 L 50,24 L 58,32" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                <Path.RenderTransform>
                    <RotateTransform Angle="-90" />
                </Path.RenderTransform>
            </Path>

            <!-- RIGHT (Rotate 90) -->
            <Path x:Name="ArrowRight" Stroke="#60FFFFFF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 42,32 L 50,24 L 58,32" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" RenderTransformOrigin="0.5,0.5">
                <Path.RenderTransform>
                    <RotateTransform Angle="90" />
                </Path.RenderTransform>
            </Path>
        </Grid>

        <!-- Center Point with Speed Indicator -->
        <Grid x:Name="SpeedIndicator" Width="36" Height="36" HorizontalAlignment="Center" VerticalAlignment="Center">
            <!-- Outer ring that pulses with scroll activity -->
            <Ellipse x:Name="SpeedRing" Width="36" Height="36" Stroke="#4064C4F5" StrokeThickness="2" Opacity="0.5"/>
            
            <!-- Inner glow -->
            <Ellipse Width="28" Height="28" Fill="#20064C4F5">
                <Ellipse.Effect>
                    <BlurEffect Radius="8"/>
                </Ellipse.Effect>
            </Ellipse>
            
            <!-- Speed text -->
            <TextBlock x:Name="SpeedText"
                       Text="0"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#80FFFFFF"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"/>
            
            <!-- Center dot -->
            <Ellipse Width="4" Height="4" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
