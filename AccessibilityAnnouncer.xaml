<Window x:Class="SoftScroll.AccessibilityAnnouncer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Accessibility Announcer"
        Width="0" Height="0"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Border Background="#E0000000"
            CornerRadius="8"
            Padding="16,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Opacity="0.95">
        <TextBlock x:Name="AnnouncementText"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="White"
                   TextAlignment="Center"
                   MaxWidth="400"
                   TextWrapping="Wrap"/>
    </Border>
</Window>
